<Window x:Class="TerminalWindowManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:TerminalWindowManager.App.Controls"
        xmlns:models="clr-namespace:TerminalWindowManager.Core.Models;assembly=TerminalWindowManager.Core"
        mc:Ignorable="d"
        Title="Terminal Window Manager"
        Height="780"
        Width="1280"
        MinHeight="680"
        MinWidth="1080">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#F5F5F5"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,1,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Projects and terminals"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <TreeView x:Name="ProjectTree"
                          Grid.Row="1"
                          SelectedItemChanged="ProjectTree_SelectedItemChanged">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type models:TerminalProject}"
                                                  ItemsSource="{Binding Tabs}">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold" />
                        </HierarchicalDataTemplate>

                        <DataTemplate DataType="{x:Type models:ManagedTerminalTab}">
                            <StackPanel Margin="0,2,0,2">
                                <TextBlock Text="{Binding Name}" />
                                <Border x:Name="TerminalProgressBadge"
                                        Margin="0,4,24,0"
                                        Padding="6,2"
                                        CornerRadius="999"
                                        Background="#DBEAFE"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="TerminalProgressDot"
                                                 Width="8"
                                                 Height="8"
                                                 Margin="0,0,6,0"
                                                 Fill="#2563EB" />
                                        <TextBlock Text="{Binding ProgressDisplayText}"
                                                   FontSize="11"
                                                   Foreground="#1F2937" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding ProgressState}"
                                             Value="{x:Static models:TerminalProgressState.None}">
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Visibility"
                                            Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ProgressState}"
                                             Value="{x:Static models:TerminalProgressState.Normal}">
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Visibility"
                                            Value="Visible" />
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Background"
                                            Value="#DBEAFE" />
                                    <Setter TargetName="TerminalProgressDot"
                                            Property="Fill"
                                            Value="#2563EB" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ProgressState}"
                                             Value="{x:Static models:TerminalProgressState.Error}">
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Visibility"
                                            Value="Visible" />
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Background"
                                            Value="#FEE2E2" />
                                    <Setter TargetName="TerminalProgressDot"
                                            Property="Fill"
                                            Value="#DC2626" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ProgressState}"
                                             Value="{x:Static models:TerminalProgressState.Indeterminate}">
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Visibility"
                                            Value="Visible" />
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Background"
                                            Value="#DCFCE7" />
                                    <Setter TargetName="TerminalProgressDot"
                                            Property="Fill"
                                            Value="#16A34A" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ProgressState}"
                                             Value="{x:Static models:TerminalProgressState.Warning}">
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Visibility"
                                            Value="Visible" />
                                    <Setter TargetName="TerminalProgressBadge"
                                            Property="Background"
                                            Value="#FEF3C7" />
                                    <Setter TargetName="TerminalProgressDot"
                                            Property="Fill"
                                            Value="#D97706" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemsSource>
                        <Binding Path="Projects" />
                    </TreeView.ItemsSource>
                </TreeView>

                <StackPanel Grid.Row="2"
                            Margin="0,12,0,0">
                    <TextBlock Text="New project"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Create project"
                            Command="{Binding CreateProjectCommand}"
                            Margin="0,8,0,0"
                            Padding="10,6" />
                </StackPanel>

                <GroupBox Grid.Row="3"
                          Header="Add terminal to selected project"
                          Margin="0,12,0,0">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Name"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding NewTerminalName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1"
                                   Text="Directory"
                                   Margin="0,10,0,0"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,10,0,0"
                                 Text="{Binding NewTerminalWorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Text="Profile"
                                   Margin="0,10,0,0"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,10,0,0"
                                 Text="{Binding NewTerminalProfileName, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Row="3"
                                Grid.Column="1"
                                Content="Add terminal"
                                Command="{Binding AddTerminalCommand}"
                                Margin="0,14,0,0"
                                Padding="12,6"
                                HorizontalAlignment="Left" />
                    </Grid>
                </GroupBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#FAFAFA"
                    BorderBrush="#D8D8D8"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedTerminal.Name, TargetNullValue=Select a terminal from the tree}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="DimGray"
                               Text="{Binding SelectedProject.Name, TargetNullValue=Project: -, StringFormat=Project: {0}}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="DimGray"
                               Text="{Binding SelectedTerminal.WorkingDirectory, TargetNullValue=Working directory: -, StringFormat=Working directory: {0}}" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#4D4D4D"
                               TextWrapping="Wrap"
                               Text="Selecting a terminal launches or reconnects a dedicated Windows Terminal window and hosts it inside this frame. This keeps the project tree available while you switch terminals." />

                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Reload selected terminal"
                                Click="ReloadSelectedTerminal_Click"
                                Padding="12,6" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="2,10,2,12"
                       Foreground="#1F4E79"
                       TextWrapping="Wrap"
                       Text="{Binding StatusMessage}" />

            <Border Grid.Row="2"
                    Background="Black"
                    BorderBrush="#1E1E1E"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="6">
                <Grid>
                    <controls:TerminalWindowHost x:Name="ActiveTerminalHost" />

                    <TextBlock x:Name="EmptyFrameMessage"
                               Margin="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#D0D0D0"
                               FontSize="16"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               IsHitTestVisible="False"
                               Text="Pick a terminal in the tree to host it here." />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

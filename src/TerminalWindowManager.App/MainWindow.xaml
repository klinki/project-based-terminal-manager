<Window x:Class="TerminalWindowManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Terminal Window Manager"
        Height="760"
        Width="1220"
        MinHeight="640"
        MinWidth="980">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#F5F5F5"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,1,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Projects"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject}"
                         DisplayMemberPath="Name" />

                <StackPanel Grid.Row="2"
                            Margin="0,12,0,0">
                    <TextBlock Text="New project"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Create project"
                            Command="{Binding CreateProjectCommand}"
                            Margin="0,8,0,0"
                            Padding="10,6" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="#FAFAFA"
                    BorderBrush="#D8D8D8"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedProject.Name, TargetNullValue=Select a project to begin}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="DimGray"
                               Text="{Binding SelectedProject.WindowTarget, TargetNullValue=Window target: -, StringFormat=Window target: {0}}" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#4D4D4D"
                               TextWrapping="Wrap"
                               Text="This proof of concept launches named Windows Terminal windows and appends tabs into them. It does not embed Terminal content, and focus recovery is best-effort for windows launched from this app." />

                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="Open project window"
                                Command="{Binding LaunchProjectWindowCommand}"
                                Margin="0,0,10,0"
                                Padding="12,6" />
                        <Button Content="Focus project window"
                                Command="{Binding FocusProjectWindowCommand}"
                                Margin="0,0,10,0"
                                Padding="12,6" />
                        <Button Content="Open all tabs"
                                Command="{Binding LaunchAllTabsCommand}"
                                Padding="12,6" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="2,10,2,12"
                       Foreground="#1F4E79"
                       TextWrapping="Wrap"
                       Text="{Binding StatusMessage}" />

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Configured terminal tabs"
                          Margin="0,0,12,0">
                    <ListBox ItemsSource="{Binding SelectedProject.Tabs}"
                             SelectedItem="{Binding SelectedTab}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding DisplayLabel}" />
                                    <TextBlock FontSize="12"
                                               Foreground="DimGray"
                                               Text="{Binding WorkingDirectory}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <GroupBox Grid.Column="1"
                          Header="Selected tab details">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Name"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedTab.Name, TargetNullValue=-}" />

                        <TextBlock Grid.Row="1"
                                   Text="Working directory"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedTab.WorkingDirectory, TargetNullValue=-}" />

                        <TextBlock Grid.Row="2"
                                   Text="Profile"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   Text="{Binding SelectedTab.ProfileName, TargetNullValue=(default)}" />

                        <TextBlock Grid.Row="3"
                                   Text="Launch state"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   Text="{Binding SelectedTab.State, TargetNullValue=-}" />

                        <WrapPanel Grid.Row="4"
                                   Grid.ColumnSpan="2"
                                   Margin="0,18,0,0">
                            <Button Content="Launch selected tab"
                                    Command="{Binding LaunchSelectedTabCommand}"
                                    Padding="12,6" />
                        </WrapPanel>

                        <TextBlock Grid.Row="5"
                                   Grid.ColumnSpan="2"
                                   Margin="0,18,0,0"
                                   Foreground="DimGray"
                                   TextWrapping="Wrap"
                                   Text="Tab focus is intentionally conservative in this first POC. Launch commands append tabs into the project's named Terminal window, and the app focuses the project window itself when possible." />
                    </Grid>
                </GroupBox>
            </Grid>

            <GroupBox Grid.Row="3"
                      Header="Add a tab to the selected project"
                      Margin="0,14,0,0">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Tab name"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding NewTabName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="1"
                               Text="Working directory"
                               Margin="0,10,0,0"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             Text="{Binding NewTabWorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2"
                               Text="Profile (optional)"
                               Margin="0,10,0,0"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             Text="{Binding NewTabProfileName, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Row="3"
                            Grid.Column="1"
                            Content="Add tab"
                            Command="{Binding AddTabCommand}"
                            Margin="0,14,0,0"
                            Padding="12,6"
                            HorizontalAlignment="Left" />
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>

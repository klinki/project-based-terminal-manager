{
	"name": "terminal-window-manager-tauri",
	"version": "0.3.0",
	"type": "module",
	"description": "Tauri + xterm.js + ConPTY desktop shell for project-based terminal switching.",
	"scripts": {
		"build:sync-version": "node scripts/sync-tauri-version.mjs",
		"build:build-info": "node scripts/sync-tauri-version.mjs && node scripts/generate-build-info.mjs",
		"build:host": "dotnet build ../TerminalWindowManager.ConPTYHost/TerminalWindowManager.ConPTYHost.csproj -v minimal -nologo",
		"build:view": "bun run build:build-info && vite build",
		"hmr": "bun run build:build-info && vite --port 5173",
		"start": "bun run dev",
		"dev": "bun run build:host && bun run tauri dev",
		"dev:hmr": "bun run build:host && bun run tauri dev",
		"tauri": "tauri",
		"build:desktop": "bun run build:host && bun run tauri build"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.0.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0"
	},
	"devDependencies": {
		"@tauri-apps/cli": "^2.0.0",
		"@types/bun": "latest",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}

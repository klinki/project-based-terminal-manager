<Window x:Class="ProjectWindowManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectWindowManager.App"
        xmlns:controls="clr-namespace:ProjectWindowManager.App.Controls"
        mc:Ignorable="d"
        Title="Project Window Manager" Height="600" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Projects" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                <ListBox x:Name="ProjectsList" Grid.Row="1" ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}" DisplayMemberPath="Name" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Text="Applications" FontSize="16" FontWeight="SemiBold" Margin="0,150,0,5" Visibility="{Binding SelectedProject, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                
                <ListBox Grid.Row="1" Margin="0,175,0,0" ItemsSource="{Binding SelectedProject.Applications}" SelectedItem="{Binding ActiveApplication}" DisplayMemberPath="DisplayName" Visibility="{Binding SelectedProject, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>

                <StackPanel Grid.Row="2">
                    <TextBox x:Name="NewProjectName" Margin="0,0,0,5"/>
                    <Button Content="New Project" Command="{Binding CreateProjectCommand}" CommandParameter="{Binding Text, ElementName=NewProjectName}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Pane -->
        <Grid Grid.Column="1" x:Name="MainPane">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="10" Visibility="{Binding SelectedProject, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                <Button Content="Launch App" Margin="0,0,10,0" Padding="10,5" Click="LaunchApp_Click"/>
                <TextBlock Text="{Binding SelectedProject.Name}" FontSize="16" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.RowSpan="2" Text="Select a project or application" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding SelectedProject, Converter={StaticResource NullToVisibilityConverter}}"/>

            <!-- Persistent Window Host -->
            <Border Grid.Row="1" Background="Black" Margin="10" Visibility="{Binding SelectedProject, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                <controls:WindowHost x:Name="ActiveWindowHost"/>
            </Border>
        </Grid>
    </Grid>
</Window>
